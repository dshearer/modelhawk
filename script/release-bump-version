#!/bin/bash

# get new version from command line argument
if [ -z "$1" ]; then
  echo "Usage: $0 <new_version>"
  exit 1
fi

# if new version doesn't start with "v", add it
if [ "${1:0:1}" != "v" ]; then
  NEW_VERSION="v$1"
else
  NEW_VERSION="$1"
fi

# make sure version's major number is 0
MAJOR_VERSION=$(echo "$NEW_VERSION" | cut -d. -f1 | tr -d 'v')
if [ "$MAJOR_VERSION" != "0" ]; then
  echo "Only major version 0 is supported. Please use a version like v0.x.y."
  exit 1
fi

# make sure we have main checked out and that there are no changes
git checkout main
if ! git diff --quiet; then
  echo "You have uncommitted changes. Please commit or stash them before running this script."
  exit 1
fi

# make new branch named after new version
git checkout -b "bump-version-$NEW_VERSION"

# update version in package-config/ts/package.json
PACKAGE_JSON_PATH="package-config/ts/package.json"
if [ ! -f "$PACKAGE_JSON_PATH" ]; then
  echo "Could not find $PACKAGE_JSON_PATH. Please make sure you are running this script from the root of the repository."
  exit 1
fi
jq --arg new_version "$NEW_VERSION" '.version = $new_version' "$PACKAGE_JSON_PATH" > "$PACKAGE_JSON_PATH.tmp" && mv "$PACKAGE_JSON_PATH.tmp" "$PACKAGE_JSON_PATH"

# generate code
make -j

# commit changes
git add .
git commit -m "Bump version to $NEW_VERSION"

# push branch to origin
git push origin "bump-version-$NEW_VERSION"

CURRENT_VERSION=$(jq -r '.version' "$PACKAGE_JSON_PATH")
echo "Version bumped from $CURRENT_VERSION to $NEW_VERSION and pushed to branch bump-version-$NEW_VERSION. Please create a pull request to merge this branch into main."